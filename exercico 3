#include <iostream>
using namespace std;

int main() {
double diagonal, area;

 cout << "Digite o valor da diagonal do quadrado: ";
 cin >> diagonal;

 if (diagonal <= 0) {
cout << "Por favor, digite um valor positivo." << endl;
return 0; }

area = (diagonal * diagonal) / 2;

cout << "A area do quadrado e: " << area << endl;

return 0;
}
